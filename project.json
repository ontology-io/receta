{
  "name": "receta",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc --noEmit"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "bunx eslint . --max-warnings 0"
      }
    },
    "generate-llm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run scripts/generate-llm-txt.ts"
      }
    },
    "docs:build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/docs-site/build"],
      "options": {
        "command": "cd docs-site && bun install && bun run build"
      }
    },
    "docs:deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["docs:build"],
      "options": {
        "command": "bash scripts/deploy-docs.sh"
      }
    }
  },
  "tags": []
}
