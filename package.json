{
  "name": "receta",
  "version": "0.1.0",
  "description": "Practical FP recipes built on Remeda — higher-level patterns for real-world TypeScript applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./result": {
      "import": "./dist/result/index.js",
      "types": "./dist/result/index.d.ts"
    },
    "./option": {
      "import": "./dist/option/index.js",
      "types": "./dist/option/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate-llm": "bun run scripts/generate-llm-txt.ts"
  },
  "keywords": [
    "functional-programming",
    "fp",
    "utilities",
    "typescript",
    "remeda",
    "result",
    "option",
    "either"
  ],
  "dependencies": {
    "remeda": "^2.19.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
