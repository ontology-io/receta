{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@ontologyio/receta": ["../receta/src/index.ts"],
      "@ontologyio/receta/*": ["../receta/src/*/index.ts"]
    }
  },
  "references": [
    { "path": "../receta" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
